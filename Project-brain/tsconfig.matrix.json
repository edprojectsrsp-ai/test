{
  "compilerOptions": {
    "target": "ES2020", "lib": ["dom", "es2021"], "jsx": "preserve",
    "module": "esnext", "moduleResolution": "bundler", "strict": true,
    "skipLibCheck": true, "noEmit": true, "esModuleInterop": true,
    "resolveJsonModule": true, "allowJs": false,
    "paths": { "@/*": ["./*"] }
  },
  "include": ["app/report-studio/matrix/**/*.ts", "app/report-studio/matrix/**/*.tsx",
              "next-env.d.ts"]
}
