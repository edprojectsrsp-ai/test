{
  "name": "project-brain-diary-android",
  "version": "1.0.0",
  "description": "Project Brain field diary - native Android wrapper",
  "scripts": {
    "build:web": "cd ../../frontend && npm run build && npm run export",
    "sync": "npx cap sync android",
    "open:android": "npx cap open android",
    "build:apk": "cd android && ./gradlew assembleDebug",
    "build:release": "cd android && ./gradlew assembleRelease",
    "full-build": "npm run build:web && npm run sync && npm run build:apk",
    "install:device": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "run:device": "npm run full-build && npm run install:device"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/toast": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "typescript": "^5.4.0"
  }
}
