# DATABASE - shared with main backend
PROJECT_BRAIN_DB_URL=postgresql://postgres:abc123@127.0.0.1:5432/project_brain

# UPLOADS - shared with main backend
UPLOAD_DIR=/tmp/project_brain/uploads

# LLM PROVIDER KEYS - at least one cloud + ollama recommended
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# OLLAMA (local fallback) - leave default if running on same machine
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama
EMBED_MODEL=all-mpnet-base-v2

# TELEGRAM BOT (optional)
TELEGRAM_BOT_TOKEN=
