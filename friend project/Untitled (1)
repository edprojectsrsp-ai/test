CREATE VIEW public.v_hub_tiers AS
 WITH base AS (
         SELECT (v_scheme_portfolio.scheme_type)::text AS tier_key,
            (v_scheme_portfolio.current_status)::text AS status,
            count(*) AS scheme_count,
            COALESCE(sum(v_scheme_portfolio.current_cost_cr), (0)::numeric) AS total_cost_cr,
            count(*) FILTER (WHERE (v_scheme_portfolio.worst_risk_rank >= 4)) AS red_count,
            count(*) FILTER (WHERE (v_scheme_portfolio.worst_risk_rank = 3)) AS amber_count,
            count(*) FILTER (WHERE (v_scheme_portfolio.worst_risk_rank <= 2)) AS green_count
           FROM public.v_scheme_portfolio
          GROUP BY v_scheme_portfolio.scheme_type, v_scheme_portfolio.current_status
        )
 SELECT tier_key,
    sum(scheme_count) AS total_count,
    sum(scheme_count) FILTER (WHERE (status <> ALL (ARRAY['closed'::text, 'dropped'::text]))) AS ongoing_count,
    sum(scheme_count) FILTER (WHERE (status = 'closed'::text)) AS closed_count,
    sum(scheme_count) FILTER (WHERE (status = 'dropped'::text)) AS dropped_count,
    sum(total_cost_cr) AS total_cost_cr,
    sum(total_cost_cr) FILTER (WHERE (status <> ALL (ARRAY['closed'::text, 'dropped'::text]))) AS ongoing_cost_cr,
    sum(red_count) AS red_count,
    sum(amber_count) AS amber_count,
    sum(green_count) AS green_count
   FROM base
  GROUP BY tier_key;


