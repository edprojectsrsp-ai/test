    s2.firmed_up_cost_net_itc_cr AS stage2_cost_net_itc_cr,
    s2.sanction_date AS stage2_sanction_date,
    so.order_id AS active_order_id,
    so.loa_date,
    so.effective_date,
    so.schedule_completion_date,
    so.contract_value_cr,
    sc.closure_id,
