-- TOC entry 5749 (class 2618 OID 25160)
-- Name: v_cpm_schedule_summary _RETURN; Type: RULE; Schema: public; Owner: postgres
--

CREATE OR REPLACE VIEW public.v_cpm_schedule_summary AS
 SELECT s.schedule_id,
    s.package_id,
    p.package_name,
    sm.scheme_id,
    sm.scheme_name,
    sm.scheme_code,
    s.schedule_name,
    s.schedule_version,
    (s.status)::text AS status,
    s.project_start_date,
    s.project_finish_date,
    s.data_date,
    count(a.activity_id) FILTER (WHERE (NOT a.is_deleted)) AS total_activities,
    count(a.activity_id) FILTER (WHERE (a.is_critical AND (NOT a.is_deleted))) AS critical_activities,
    count(a.activity_id) FILTER (WHERE ((a.activity_status = 'completed'::public.cpm_activity_status_enum) AND (NOT a.is_deleted))) AS completed,
    count(a.activity_id) FILTER (WHERE ((a.activity_status = 'in_progress'::public.cpm_activity_status_enum) AND (NOT a.is_deleted))) AS in_progress,
    count(a.activity_id) FILTER (WHERE ((a.activity_status = 'not_started'::public.cpm_activity_status_enum) AND (NOT a.is_deleted))) AS not_started,
    round(avg(a.physical_pct_complete) FILTER (WHERE (NOT a.is_deleted)), 2) AS avg_pct_complete,
    s.is_current_baseline,
    s.last_cpm_run_at
   FROM (((public.cpm_schedules s
     LEFT JOIN public.cpm_activities a ON ((a.schedule_id = s.schedule_id)))
     LEFT JOIN public.packages p ON ((p.package_id = s.package_id)))
     LEFT JOIN public.scheme_master sm ON ((sm.scheme_id = p.scheme_id)))
  WHERE (NOT s.is_deleted)
  GROUP BY s.schedule_id, p.package_name, sm.scheme_id, sm.scheme_name, sm.scheme_code;


