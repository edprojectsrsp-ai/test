    sm.scheme_type,
    sm.current_status,
    COALESCE(s2.firmed_up_cost_net_itc_cr, s1.cost_net_itc_cr, f.cost_net_itc_cr, sm.estimated_cost_cr) AS current_cost_cr,
    sm.sanctioned_cost_cr,
    sm.anticipated_cost_cr,
    ( SELECT count(*) AS count
           FROM public.packages p
          WHERE ((p.scheme_id = sm.scheme_id) AND (NOT p.is_deleted))) AS package_count,
    ( SELECT count(*) AS count
           FROM public.packages p
          WHERE ((p.scheme_id = sm.scheme_id) AND (NOT p.is_deleted) AND (NOT p.is_scheme_mirror))) AS real_package_count,
    ( SELECT round(avg(ppm.actual_progress_pct), 2) AS round
           FROM (public.plant_progress_monthly ppm
             JOIN public.packages p ON ((p.package_id = ppm.package_id)))
          WHERE ((p.scheme_id = sm.scheme_id) AND (ppm.month_date = ( SELECT max(plant_progress_monthly.month_date) AS max
                   FROM public.plant_progress_monthly
                  WHERE (plant_progress_monthly.package_id IN ( SELECT packages.package_id
                           FROM public.packages
                          WHERE (packages.scheme_id = sm.scheme_id))))))) AS latest_actual_progress_pct,
    ( SELECT max(
                CASE ri.risk_level
                    WHEN 'red'::public.risk_level_enum THEN 4
                    WHEN 'amber'::public.risk_level_enum THEN 3
                    WHEN 'green'::public.risk_level_enum THEN 2
                    ELSE 1
                END) AS max
           FROM public.risk_indicators ri
          WHERE (((ri.scheme_id = sm.scheme_id) OR (ri.package_id IN ( SELECT packages.package_id
                   FROM public.packages
                  WHERE (packages.scheme_id = sm.scheme_id)))) AND (ri.is_active = true))) AS worst_risk_rank,
    sm.planned_start_date,
    sm.planned_completion_date,
    sm.actual_start_date,
    sm.actual_completion_date,
    sm.scheme_owner_id,
    sm.scheme_owner_name,
    ( SELECT array_agg(t.tag_name ORDER BY t.tag_name) AS array_agg
           FROM (public.scheme_tag_links stl
             JOIN public.scheme_tags t ON ((t.tag_id = stl.tag_id)))
          WHERE (stl.scheme_id = sm.scheme_id)) AS tags,
    ( SELECT count(*) AS count
           FROM public.documents d
          WHERE ((d.scheme_id = sm.scheme_id) AND (NOT d.is_deleted))) AS doc_count,
    sm.created_at,
    sm.updated_at
   FROM (((public.scheme_master sm
     LEFT JOIN public.scheme_formulation f ON (((f.scheme_id = sm.scheme_id) AND (f.is_current = true))))
     LEFT JOIN public.stage1_approvals s1 ON (((s1.scheme_id = sm.scheme_id) AND (s1.is_current = true))))
     LEFT JOIN public.stage2_approvals s2 ON (((s2.scheme_id = sm.scheme_id) AND (s2.is_current = true))))
  WHERE (NOT sm.is_deleted);


