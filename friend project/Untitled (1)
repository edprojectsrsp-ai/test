-- Name: fn_generate_notesheet_no(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.fn_generate_notesheet_no() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
    yr TEXT;
    next_seq INTEGER;
BEGIN
    IF NEW.notesheet_no IS NULL OR NEW.notesheet_no = '' THEN
        yr := TO_CHAR(CURRENT_DATE, 'YYYY');
        SELECT COALESCE(MAX(CAST(SUBSTRING(notesheet_no FROM 11) AS INTEGER)), 0) + 1
            INTO next_seq
            FROM notesheets
            WHERE notesheet_no LIKE 'PB/NS/' || yr || '/%';
        NEW.notesheet_no := 'PB/NS/' || yr || '/' || LPAD(next_seq::text, 4, '0');
    END IF;
    RETURN NEW;
END;
$$;


