# Sprint 0 — backend env template
JWT_SECRET=change-me-in-env-pb-secret
PB_AUTH_SECRET=change-me-in-env-pb-secret
# Set to 0 only for emergency local demos without login
PB_AUTH_ENFORCE=1
JWT_EXPIRY_HOURS=12

# Comma-separated browser origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Durable uploads (defaults to project-brain-backend/uploads)
# UPLOAD_DIR=
# UPLOAD_BACKUP_DIR=

PROJECT_BRAIN_DB_URL=postgresql://postgres:abc123@127.0.0.1:5432/project_brain
